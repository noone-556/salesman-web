{
  "version": 2,
  "framework": null,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "outputDirectory": "public",
  "routes": [
  {
    "src": "/favicon.ico",
    "dest": "/public/favicon.ico"
  },
  {
    "src": "/css/(.*)",
    "dest": "/public/css/$1"
  },
  {
    "src": "/js/(.*)",
    "dest": "/public/js/$1"
  },
  {
    "src": "/build/(.*)",
    "dest": "/public/build/$1"
  },
  {
    "src": "/(.*)",
    "dest": "/api/index.php"
  }
]
}